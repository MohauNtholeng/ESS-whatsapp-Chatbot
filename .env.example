# Twilio credentials - copy this file to .env and fill in your values
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server configuration
PORT=3000

# Twilio Content Template SIDs for WhatsApp interactive buttons (optional)
# Leave these blank to fall back to plain-text replies automatically.
# Create the templates in the Twilio Console under:
#   Messaging → Content Template Builder → Create new template
#
# Both templates should use type "Quick Reply".  Set each button's "id" to the
# number the state machine expects:
#
#   MAIN_MENU  — buttons: id="1" title="View Leave Balance"
#                          id="2" title="Apply for Leave"
#                          id="3" title="Request Pay Slip"
#
#   LEAVE_TYPE — buttons: id="1" title="Annual Leave"
#                          id="2" title="Sick Leave"
#                          id="3" title="Family Leave"
#                          id="0" title="Cancel"
#
TWILIO_CONTENT_SID_MAIN_MENU=
TWILIO_CONTENT_SID_LEAVE_TYPE=
